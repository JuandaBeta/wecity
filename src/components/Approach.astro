---
// Approach.astro
import { approach } from '../data/content.ts';
---

<section class="approach section-pad" id="approach">
  <div class="container">
    <!-- Header -->
    <div class="approach__header fade-up">
      <p class="label" data-i18n="approach.label">Our Methodology</p>
      <h2 class="display-lg" data-i18n="approach.title">
        Open &amp; Hybrid<br/>
        <span class="accent">Collaborative</span> Approach
      </h2>
    </div>

    <!-- Steps -->
    <div class="approach__steps">
      {approach.map((step, i) => (
        <article class={`approach__step fade-up ${i % 2 !== 0 ? 'reverse' : ''}`} style={`--delay: ${i * 0.1}s`}>
          <!-- Number -->
          <div class="approach__step-num">{step.number}</div>

          <!-- Image -->
          <div class="approach__step-img">
            <img src={step.image} alt={step.title} loading="lazy" decoding="async" />
          </div>

          <!-- Text -->
          <div class="approach__step-body">
            <h3 class="approach__step-title display-md" data-i18n={`approach.${i}.title`}>{step.title}</h3>
            <p class="approach__step-desc" data-i18n={`approach.${i}.desc`}>{step.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .approach__header {
    margin-bottom: 4rem;
    max-width: 640px;
  }
  .approach__header .label { margin-bottom: 1rem; }

  .approach__steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .approach__step {
    display: grid;
    grid-template-columns: 80px 1fr 1fr;
    min-height: 360px;
    gap: 2rem;
    align-items: center;
    padding: 2.5rem 0;
    border-top: 1px solid var(--col-border);
    transition-delay: var(--delay);
  }
  .approach__step:last-child { border-bottom: 1px solid var(--col-border); }

  .approach__step-num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--col-accent);
    opacity: 0.7;
  }

  .approach__step-img {
    aspect-ratio: 16/9;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--col-surface);
  }
  .approach__step-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }
  .approach__step:hover .approach__step-img img {
    transform: scale(1.04);
  }

  .approach__step-title {
    margin-bottom: 0.75rem;
  }

  .approach__step-desc {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 300;
    line-height: 1.75;
    color: var(--col-text-dim);
  }

  .approach__step.reverse .approach__step-img {
    order: 3;
  }
  .approach__step.reverse .approach__step-body {
    order: 2;
  }

  @media (max-width: 900px) {
    .approach__step {
      grid-template-columns: 48px 1fr;
      grid-template-rows: auto auto;
    }
    .approach__step-num { grid-column: 1; grid-row: 1; align-self: start; padding-top: 0.3rem; }
    .approach__step-body { grid-column: 2; grid-row: 1; }
    .approach__step-img { grid-column: 1 / -1; grid-row: 2; }
  }

  @media (max-width: 600px) {
    .approach__step {
      grid-template-columns: 1fr;
    }
    .approach__step-num { grid-column: 1; grid-row: auto; }
    .approach__step-body { grid-column: 1; }
    .approach__step-img { grid-column: 1; }
  }
</style>