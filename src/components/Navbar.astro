---
// Navbar.astro
---

<header class="navbar" id="navbar">
  <div class="navbar__inner container">
    <!-- Logo -->
    <a href="/" class="navbar__logo">
      <span class="navbar__logo-mark">WE</span><span class="navbar__logo-city">CITY</span>
    </a>

    <!-- Desktop nav -->
    <nav class="navbar__nav" aria-label="Main navigation">
      <a href="#approach"     class="navbar__link" data-i18n="nav.approach">Our Approach</a>
      <a href="#keynotes"     class="navbar__link" data-i18n="nav.keynotes">Keynotes</a>
      <a href="#stakeholders" class="navbar__link" data-i18n="nav.stakeholders">Who We Are</a>
      <a href="#projects"     class="navbar__link" data-i18n="nav.projects">Projects</a>
      <a href="#stats" class="navbar__link" data-i18n="nav.stats">Impact</a>
      <a href="#contact"      class="navbar__link" data-i18n="nav.contact">Contact Us</a>
    </nav>

    <!-- Right side controls -->
    <div class="navbar__controls">

      <!-- Language toggle -->
      <button class="lang-toggle" id="langToggle" aria-label="Switch language" title="Switch language">
        <span id="langLabel">ES</span>
      </button>

      <!-- Theme toggle -->
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle light/dark mode" title="Toggle theme">
        <svg class="icon-sun" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2"  x2="12" y2="5"/>
          <line x1="12" y1="19" x2="12" y2="22"/>
          <line x1="2"  y1="12" x2="5"  y2="12"/>
          <line x1="19" y1="12" x2="22" y2="12"/>
          <line x1="4.22"  y1="4.22"  x2="6.34"  y2="6.34"/>
          <line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/>
          <line x1="4.22"  y1="19.78" x2="6.34"  y2="17.66"/>
          <line x1="17.66" y1="6.34"  x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- CTA -->
      <a href="#contact" class="btn btn-primary navbar__cta" data-i18n="nav.contact">Contact Us</a>

      <!-- Mobile toggle -->
      <button class="navbar__toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="navbar__drawer" id="navDrawer" aria-hidden="true">
    <nav class="navbar__drawer-nav">
      <a href="#approach"     class="navbar__drawer-link" data-i18n="nav.approach">Our Approach</a>
      <a href="#keynotes"     class="navbar__drawer-link" data-i18n="nav.keynotes">Keynotes</a>
      <a href="#stakeholders" class="navbar__drawer-link" data-i18n="nav.stakeholders">Who We Are</a>
      <a href="#projects"     class="navbar__drawer-link" data-i18n="nav.projects">Projects</a>
      <a href="#stats" class="navbar__drawer-link" data-i18n="nav.stats">Impact</a>
      <a href="#contact"      class="navbar__drawer-link accent" data-i18n="nav.contact.mobile">Contact Us →</a>
    </nav>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.25rem 0;
    transition: background 0.4s ease, padding 0.4s ease, backdrop-filter 0.4s ease, border-color 0.4s ease;
    border-bottom: 1px solid transparent;
  }
  .navbar.scrolled {
    background: rgba(7, 8, 8, 0.88);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    padding: 0.9rem 0;
    border-bottom-color: var(--col-border);
  }
  [data-theme="light"] .navbar.scrolled {
    background: rgba(247, 245, 239, 0.9);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* Logo */
  .navbar__logo {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 1.3rem;
    letter-spacing: 0.02em;
    display: flex;
  }
  .navbar__logo-mark { color: var(--col-accent); font-style: italic; }
  .navbar__logo-city { color: var(--col-white); }

  /* Desktop nav links */
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .navbar__link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.77rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--col-text-dim);
    transition: color 0.2s;
  }
  .navbar__link:hover { color: var(--col-white); }

  /* Right controls group */
  .navbar__controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .navbar__cta { font-size: 0.74rem; padding: 0.58rem 1.2rem; }

  /* Language toggle */
  .lang-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--col-surface);
    border: 1px solid var(--col-border);
    cursor: pointer;
    transition: background 0.25s, border-color 0.25s, color 0.25s;
    color: var(--col-text-dim);
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }
  .lang-toggle:hover {
    border-color: var(--col-accent);
    color: var(--col-accent);
  }

  /* Mobile toggle */
  .navbar__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
  }
  .navbar__toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--col-text);
    border-radius: 2px;
    transition: all 0.25s var(--ease-out);
  }
  .navbar__toggle.open span:nth-child(1) { transform: rotate(45deg) translate(4.5px, 4.5px); }
  .navbar__toggle.open span:nth-child(2) { opacity: 0; }
  .navbar__toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(4.5px, -4.5px); }

  /* Mobile drawer */
  .navbar__drawer {
    display: none;
    padding: 1.5rem 0 2rem;
    border-top: 1px solid var(--col-border);
    background: var(--col-bg);
  }
  .navbar__drawer.open { display: block; }
  .navbar__drawer-nav {
    display: flex;
    flex-direction: column;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
  .navbar__drawer-link {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--col-text);
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--col-border);
    transition: color 0.2s, padding-left 0.2s;
  }
  .navbar__drawer-link:hover { color: var(--col-accent); padding-left: 0.5rem; }

  @media (max-width: 820px) {
    .navbar__nav  { display: none; }
    .navbar__cta  { display: none; }
    .navbar__toggle { display: flex; }
  }
</style>

<script>
  // ── Scroll effect ──
  const navbar = document.getElementById('navbar')!;
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 50);
  }, { passive: true });

  // ── Theme toggle ──
  const html        = document.documentElement;
  const themeToggle = document.getElementById('themeToggle')!;
  const STORAGE_KEY = 'wecity-theme';

  const saved     = localStorage.getItem(STORAGE_KEY);
  const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  html.setAttribute('data-theme', saved ?? preferred);

  themeToggle.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem(STORAGE_KEY, next);
  });



  // ── Mobile drawer ──
  const toggle = document.getElementById('navToggle')!;
  const drawer = document.getElementById('navDrawer')!;
  const dLinks = drawer.querySelectorAll('.navbar__drawer-link');

  toggle.addEventListener('click', () => {
    const isOpen = toggle.classList.toggle('open');
    drawer.classList.toggle('open', isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
    drawer.setAttribute('aria-hidden', String(!isOpen));
  });

  dLinks.forEach(link => {
    link.addEventListener('click', () => {
      toggle.classList.remove('open');
      drawer.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
    });
  });
</script>