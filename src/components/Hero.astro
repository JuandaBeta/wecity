---
// Hero.astro
---

<section class="hero" id="hero">
  <!-- Background image -->
  <div class="hero__bg">
    <img
      src="https://framerusercontent.com/images/BTzB4w5Swx6gpc8LmRsi2Dq7gw.png?width=1600"
      alt="WECITY urban ecosystem"
      loading="eager"
      decoding="async"
    />
    <div class="hero__overlay"></div>
  </div>

  <!-- Content -->
 

    <!-- Scroll cue -->
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-line"></span>
      <span class="hero__scroll-label label"></span>
    </div>
  </div>

  <!-- Bottom tag bar -->
  <div class="hero__tagbar">
    <div class="hero__tagbar-inner container">
      <span>Open Innovation</span>
      <span class="hero__tagbar-sep">·</span>
      <span>Human-Centered</span>
      <span class="hero__tagbar-sep">·</span>
      <span>Co-Creation</span>
      <span class="hero__tagbar-sep">·</span>
      <span>Conscious Cities</span>
      <span class="hero__tagbar-sep">·</span>
      <span>Medellín · Colombia</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* Background */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: right center;
    transform: scale(1.05);
    animation: heroZoom 12s var(--ease-out) forwards;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(8,9,7,0.100) 0%, rgba(8,9,7,0.3) 100%),
      linear-gradient(to top,   rgba(8,9,7,0.12)  0%,  transparent      50%);
  }

  @keyframes heroZoom {
    from { transform: scale(1.3); }
    to   { transform: scale(1.0); }
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 1;
    padding-top: 8rem;
    padding-bottom: 6rem;
    max-width: 900px;
  }

  .hero__label {
    margin-bottom: 1.5rem;
    animation: fadeUp 0.8s 0.2s var(--ease-out) both;
  }

  .hero__heading {
    margin-bottom: 1.75rem;
  }
  .hero__heading-line {
    display: block;
    animation: fadeUp 0.8s var(--ease-out) both;
  }
  .hero__heading-line:nth-child(1) { animation-delay: 0.3s; }
  .hero__heading-line:nth-child(2) { animation-delay: 0.45s; }
  .hero__heading-line:nth-child(3) { animation-delay: 0.6s; }
  .hero__heading-line--accent { color: var(--col-accent); }

  .hero__sub {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(232, 228, 216, 0.75);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s 0.75s var(--ease-out) both;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    animation: fadeUp 0.8s 0.9s var(--ease-out) both;
  }

 
  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--col-accent), transparent);
    animation: scrollPulse 2s infinite;
  }
  .hero__scroll-label { writing-mode: vertical-lr; }

  @keyframes scrollPulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  /* Tag bar */
  .hero__tagbar {
    margin-top: auto;
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 1rem 0;
    background: rgba(8,9,7,0.5);
    backdrop-filter: blur(8px);
  }
  .hero__tagbar-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 0;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--col-text-dim);
  }
  .hero__tagbar-sep { color: var(--col-accent); padding: 0 0.25rem; }

  /* Shared keyframe */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .hero__scroll { display: none; }
  }
</style>
