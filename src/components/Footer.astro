---
// Footer.astro
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <span class="accent">WE</span>CITY<span class="logo__reg">®</span>
        </a>
        <p class="footer__tagline" data-i18n="hero.label">Living Urban Ecosystems</p>
        <p class="footer__desc" data-i18n="about.text_short">
          Co-creating and implementing projects with soul that inspire
          and transform urban territories.
        </p>
      </div>

      <nav class="footer__nav">
        <div class="footer__nav-group">
          <a href="#approach" class="footer__link" data-i18n="nav.approach">Our Approach</a>
          <a href="#keynotes" class="footer__link" data-i18n="nav.keynotes">Learn How</a>
          <a href="#stakeholders" class="footer__link" data-i18n="nav.stakeholders">Ecosystem</a>
        </div>
        <div class="footer__nav-group">
          <a href="#projects" class="footer__link" data-i18n="nav.projects">Projects</a>
          <a href="#stats" class="footer__link" data-i18n="nav.stats">Impact</a>
          <a href="#contact" class="footer__link" data-i18n="nav.contact">Contact</a>
        </div>
      </nav>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">
        © {new Date().getFullYear()} 
        <span class="footer__copy-brand">
          WECITY<span class="copy__reg">®</span>
        </span>. 
        <span data-i18n="footer.rights">All rights reserved.</span>
        <span data-i18n="footer.made_in">Made in</span> <span class="accent" data-i18n="footer.location">Medellín, Colombia</span>.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer__logo {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--col-white);
    text-decoration: none;
    display: flex; 
    align-items: baseline;
    line-height: 1;
  }

  .logo__reg {
    font-size: 2.3rem;
    color: var(--col-accent);
    margin-left: 6px;
    font-weight: 400;
  }

  .footer__copy-brand {
    color: var(--col-white);
    font-weight: 700;
    display: inline-flex;
    align-items: baseline;
  }

  .copy__reg {
    font-size: 1.1rem;
    color: var(--col-accent);
    margin-left: 2px;
    line-height: 0;
  }

  .footer__tagline {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--col-accent);
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .footer { background: var(--col-bg); border-top: 1px solid var(--col-border); padding: 6rem 0 3rem; }
  .footer__top { display: flex; justify-content: space-between; gap: 4rem; margin-bottom: 5rem; }
  .footer__brand { max-width: 420px; }
  .footer__nav { display: flex; gap: 4rem; }
  .footer__nav-group { display: flex; flex-direction: column; gap: 1.2rem; }
  .footer__link { font-size: 0.85rem; font-weight: 500; text-transform: uppercase; color: var(--col-text-dim); text-decoration: none; }
  .footer__bottom { padding-top: 2.5rem; border-top: 1px solid var(--col-border); }
  .footer__copy { font-size: 0.9rem; color: var(--col-text-dim); display: flex; align-items: baseline; gap: 4px; flex-wrap: wrap; }
  .accent { color: var(--col-accent); }
  
  @media (max-width: 900px) {
    .footer__top { flex-direction: column; }
    .footer__nav { gap: 3rem; }
  }
</style>