---
import { stats } from '../data/content.ts';
---

<section class="stats section-pad" id="stats">
  <div class="container">
    <p class="label stats__title" data-i18n="stats.label">Impact</p>
    
    <div class="stats__grid">
      {stats.map((s, i) => {
        // Lógica para separar números de símbolos (ej: "18" y "+")
        const numberMatch = s.value.match(/\d+/);
        const number = numberMatch ? numberMatch[0] : "0";
        const suffix = s.value.replace(number, "");

        return (
          <div class="stats__item fade-up" style={`--delay: ${i * 0.15}s`}>
            <div class="stats__number-wrapper">
              <span 
                class="stats__number accent counter" 
                data-target={number}
              >0</span>
              <span class="stats__suffix accent">{suffix}</span>
            </div>
            <p class="stats__label label">{s.label}</p>
          </div>
        )
      })}
    </div>
  </div>
</section>

<script>
  const startCounter = (el: HTMLElement) => {
    const target = parseInt(el.getAttribute('data-target') || '0');
    const duration = 2000; // 2 segundos de animación
    const stepTime = 20;
    const steps = duration / stepTime;
    const increment = target / steps;
    let current = 0;

    const timer = setInterval(() => {
      current += increment;
      if (current >= target) {
        el.innerText = target.toString();
        
        // ACTIVAR EFECTO GLOW AL FINALIZAR
        el.classList.add('glow-active');
        // También aplicamos al sufijo (el hermano siguiente en el DOM)
        if (el.nextElementSibling) {
          el.nextElementSibling.classList.add('glow-active');
        }
        
        clearInterval(timer);
      } else {
        el.innerText = Math.floor(current).toString();
      }
    }, stepTime);
  };

  // Intersection Observer para disparar la animación al hacer scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const counters = entry.target.querySelectorAll('.counter');
        counters.forEach(c => startCounter(c as HTMLElement));
        observer.unobserve(entry.target); // Solo se anima una vez
      }
    });
  }, { threshold: 0.4 });

  const statsSection = document.querySelector('#stats');
  if (statsSection) observer.observe(statsSection);
</script>

<style>
  .stats {
    border-top: 1px solid var(--col-border);
    border-bottom: 1px solid var(--col-border);
  }

  .stats__title {
    text-align: center;
    margin-bottom: 4rem;
    display: block;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--col-border);
    border: 1px solid var(--col-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .stats__item {
    background: var(--col-bg);
    padding: 4.5rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: background 0.4s ease;
  }

  .stats__item:hover {
    background: var(--col-surface);
  }

  .stats__number-wrapper {
    display: flex;
    align-items: baseline;
    justify-content: center;
  }

  /* Tipografía DM Sans y configuración de Brillo */
  .stats__number, .stats__suffix {
    font-family: var(--font-body);
    font-size: clamp(2.8rem, 6vw, 4.8rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    transition: filter 0.8s var(--ease-out), text-shadow 0.8s var(--ease-out);
    filter: drop-shadow(0 0 0px rgba(166, 224, 58, 0));
  }

  /* Estado activo del resplandor (Glow) */
  .glow-active {
    filter: drop-shadow(0 0 15px rgba(166, 224, 58, 0.45));
    text-shadow: 0 0 25px rgba(166, 224, 58, 0.2);
    animation: pulse-glow 3s infinite alternate ease-in-out;
  }

  .stats__label {
    color: var(--col-text-dim);
    margin-top: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
  }

  @keyframes pulse-glow {
    from { filter: drop-shadow(0 0 10px rgba(166, 224, 58, 0.3)); }
    to { filter: drop-shadow(0 0 22px rgba(166, 224, 58, 0.6)); }
  }

  /* Responsivo para móviles */
  @media (max-width: 820px) {
    .stats__grid { 
      grid-template-columns: 1fr; 
      gap: 1px;
    }
    .stats__item {
      padding: 3rem 1.5rem;
    }
  }
</style>