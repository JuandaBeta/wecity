  function applyLang(lang: Lang) {
  const t = translations[lang];
  if (!t) return;

  // 1. Traducir textos normales e innerHTML
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n') as keyof typeof t;
    if (t[key]) {
      const htmlElement = el as HTMLElement;
      const hasHtml = /<[a-z][\s\S]*>/i.test(t[key]);
      if (hasHtml) {
        htmlElement.innerHTML = t[key];
      } else {
        htmlElement.textContent = t[key];
      }
    }
  });

  // 2. NUEVO: Traducir Placeholders (el texto de ejemplo)
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
    const key = el.getAttribute('data-i18n-placeholder') as keyof typeof t;
    if (t[key]) {
      // Forzamos el tipo a Input o TextArea para acceder a la propiedad .placeholder
      (el as HTMLInputElement | HTMLTextAreaElement).placeholder = t[key];
    }
  });

    document.documentElement.setAttribute('data-lang', lang);
    document.documentElement.setAttribute('lang', lang);
    const label = document.getElementById('langLabel');
    if (label) label.textContent = lang === 'en' ? 'ES' : 'EN';
    localStorage.setItem('wecity-lang', lang);
    }

      function initLang() {
        const saved = localStorage.getItem('wecity-lang');
        const savedLang: Lang = (saved === 'es' || saved === 'en') ? saved : 'en';
        
        applyLang(savedLang);

        const btn = document.getElementById('langToggle');
        // Solución al error de parentNode possibly null
        if (btn && btn.parentNode) {
          const newBtn = btn.cloneNode(true) as HTMLButtonElement;
          btn.parentNode.replaceChild(newBtn, btn);
          
          newBtn.addEventListener('click', (e) => {
            e.preventDefault();
            const current = document.documentElement.getAttribute('data-lang') as Lang || 'en';
            const next: Lang = current === 'en' ? 'es' : 'en';
            applyLang(next);
          });
        }
      }

      // Ejecutar inicialización
      initLang();
    </script>

